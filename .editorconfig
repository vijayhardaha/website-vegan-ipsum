# ==============================================================================
# EDITORCONFIG STYLE RULES
# ==============================================================================
# Purpose: Standardizes editor behavior (indentation, line endings, whitespace)
# across local development and CI environments.
# Docs: https://editorconfig.org/
# ==============================================================================

# ==========================================
# PROJECT SCOPE
# ==========================================
# Mark this file as the top-level EditorConfig so parent configs are ignored
root = true

# ==========================================
# GLOBAL DEFAULTS
# ==========================================
[*]
# Use UTF-8 encoding for consistent cross-platform text rendering
charset = utf-8
# Use Unix-style line endings to avoid platform-specific diffs
end_of_line = lf
# Use tabs as the project-wide indentation strategy
indent_style = tab
# Set default indentation width to four
indent_size = 4
# Ensure every file ends with a newline for POSIX compatibility
insert_final_newline = true
# Remove trailing spaces to keep diffs clean
trim_trailing_whitespace = true

# ==========================================
# TEXT FILE OVERRIDES
# ==========================================
[*.txt]
# Keep trailing spaces in plain text where manual alignment may be intentional
trim_trailing_whitespace = false
# Do not force final newline in plain text notes or generated text assets
insert_final_newline = false

# ==========================================
# MARKDOWN & YAML OVERRIDES
# ==========================================
[*.{md,yml}]
# Use a narrower indentation width for content-centric files
indent_size = 2

# ==========================================
# JSON OVERRIDES
# ==========================================
[*.json]
# Use effective two-space indentation behavior for JSON editors
indent_size = 2
