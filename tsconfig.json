{
	// ==============================================================================
	// TYPESCRIPT PROJECT CONFIGURATION
	// ==============================================================================
	// Purpose: Defines TypeScript compiler behavior, module resolution, and project
	// inclusion patterns for the Next.js application.
	// Docs: https://www.typescriptlang.org/tsconfig
	// ==============================================================================

	// --- Compiler Behavior ---
	"compilerOptions": {
		// Allow JavaScript files to participate in type-checking and project graph.
		"allowJs": true,
		// Resolve non-relative imports from the repository root.
		"baseUrl": ".",
		// Ensure iterable semantics remain correct when transpiling lower targets.
		"downlevelIteration": true,
		// Improve CommonJS interop behavior for broader package compatibility.
		"esModuleInterop": true,
		// Prevent path casing mismatches across case-sensitive file systems.
		"forceConsistentCasingInFileNames": true,
		// Reuse project graph metadata for faster subsequent type-checks.
		"incremental": true,
		// Keep each file independently transpilation-safe for toolchain compatibility.
		"isolatedModules": true,
		// Use React automatic JSX runtime.
		"jsx": "react-jsx",
		// Include DOM and iterable typings for browser runtime APIs.
		"lib": ["dom", "dom.iterable"],
		// Emit modern ECMAScript module syntax for bundler optimization.
		"module": "esnext",
		// Use Node.js module resolution behavior.
		"moduleResolution": "node",
		// Disable JS output; this project relies on Next.js build pipeline.
		"noEmit": true,

		// --- Import Aliasing ---
		// Define @/* alias to simplify imports from src.
		"paths": { "@/*": ["./src/*"] },

		// --- Framework Integration ---
		// Enable Next.js TypeScript plugin enhancements.
		"plugins": [{ "name": "next" }],

		// Allow importing JSON content as modules.
		"resolveJsonModule": true,
		// Skip .d.ts checking to improve build and editor performance.
		"skipLibCheck": true,
		// Enable full strict type-checking mode.
		"strict": true,
		// Target modern JavaScript runtime features.
		"target": "ES2024"
	},

	// --- Project Scope ---
	// Exclude dependency directories from project compilation context.
	"exclude": ["node_modules"],
	// Include source, configuration, type declarations, and generated Next.js types.
	"include": [
		"**/*.{js,jsx,ts,tsx,mjs,cjs}",
		"*.config.mjs",
		"next-env.d.ts",
		"*.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	]
}
