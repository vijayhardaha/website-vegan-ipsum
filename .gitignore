# =======================================================================
# Git Ignore
# =======================================================================
# Purpose: Prevent build artifacts, local config, and sensitive
#          credentials from entering version control.
# Docs: https://git-scm.com/docs/gitignore
# =======================================================================

# ----------------------------------------------------------------------
# Dependency Managers (Node)
# ----------------------------------------------------------------------
# Large binary folders should never be committed.
node_modules/
.pnp/
.pnp.*

# Yarn 2+ Zero-Installs support
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----------------------------------------------------------------------
# Php (Backend)
# ----------------------------------------------------------------------
# Composer dependencies
vendor/

# ----------------------------------------------------------------------
# Secrets & Security
# ----------------------------------------------------------------------
# WARNING: Do not remove these unless you have an encryption layer.
.env
.env.*
!.env.example
*.pem
.vercel

# ----------------------------------------------------------------------
# Build & Compilation Output
# ----------------------------------------------------------------------
# Next.js / React
.next/
dist/
build/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ----------------------------------------------------------------------
# Styles (Sass/Css)
# ----------------------------------------------------------------------
# Ignore compiled CSS maps if you are committing the CSS separately,
# or ignore the compiled CSS entirely if building in CI.
# *.css.map
# *.min.css

# ----------------------------------------------------------------------
# Testing & Debugging
# ----------------------------------------------------------------------
# Coverage reports
coverage/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------------------
# Editor & Ide Settings
# ----------------------------------------------------------------------
# These are developer-specific, not project-specific.
#.vscode/
.idea/
#*.swp
#*.swo

# ----------------------------------------------------------------------
# System & Os Junk
# ----------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------------------------------------------------
# Seo & Generated Data
# ----------------------------------------------------------------------
# Automatically generated files usually don't need version control
# unless your deployment process requires it.
/public/robots.txt
/public/sitemap*
*sitemap*.xml
.env*.local
