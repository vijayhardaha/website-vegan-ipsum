# ==============================================================================
# GIT IGNORE RULES
# ==============================================================================
# Purpose: Excludes generated, local, and environment-specific files so version
# control tracks only intentional source and project artifacts.
# Docs: https://git-scm.com/docs/gitignore
# ==============================================================================

# ==========================================
# PACKAGE MANAGER DEPENDENCIES
# ==========================================
# Ignore installed Node dependencies that are reproducible from lockfiles
/node_modules
# Ignore Yarn Plug'n'Play manifest directory
/.pnp
# Ignore Yarn Plug'n'Play data files
.pnp.*
# Ignore all Yarn internal metadata by default
.yarn/*
# Keep Yarn patch files in version control
!.yarn/patches
# Keep Yarn plugin definitions in version control
!.yarn/plugins
# Keep Yarn release binaries in version control
!.yarn/releases
# Keep Yarn version declarations in version control
!.yarn/versions

# ==========================================
# TEST OUTPUT
# ==========================================
# Ignore test coverage reports generated during CI and local runs
/coverage

# ==========================================
# NEXT.JS BUILD ARTIFACTS
# ==========================================
# Ignore Next.js build output directory
/.next/
# Ignore static export output directory
/out/

# ==========================================
# PRODUCTION GENERATED FILES
# ==========================================
# Ignore generic build output directory
/build
# Ignore generated robots file in public output
/public/robots.txt
# Ignore generated sitemap files in public output
/public/sitemap*
# Ignore generated local data assets
/src/data/*

# ==========================================
# OPERATING SYSTEM & LOCAL MISC FILES
# ==========================================
# Ignore macOS finder metadata
.DS_Store
# Ignore local private key files
*.pem
# Ignore Windows explorer metadata
Thumbs.db

# ==========================================
# DEBUG LOGS
# ==========================================
# Ignore npm debug logs
npm-debug.log*
# Ignore Yarn debug logs
yarn-debug.log*
# Ignore Yarn error logs
yarn-error.log*
# Ignore pnpm debug logs
.pnpm-debug.log*

# ==========================================
# ENVIRONMENT FILES
# ==========================================
# Ignore all environment variable files by default
.env*

# ==========================================
# DEPLOYMENT ARTIFACTS
# ==========================================
# Ignore Vercel local project metadata
.vercel
# Ignore root robots file when generated externally
robots.txt
# Ignore root sitemap files when generated externally
*sitemap*.xml

# ==========================================
# TYPESCRIPT CACHES
# ==========================================
# Ignore incremental TypeScript build info cache files
*.tsbuildinfo
# Ignore generated Next.js environment type declaration file
next-env.d.ts
